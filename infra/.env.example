POSTGRES_DB=opentrade
POSTGRES_USER=opentrade_owner
POSTGRES_PASSWORD=change-me-before-first-start
POSTGRES_PORT=5432

MINIO_ROOT_USER=opentrade_admin
MINIO_ROOT_PASSWORD=change-me-before-first-start
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
SNAPSHOT_BUCKET=opentrade-snapshots

# Pin reviewed immutable image digests in production.
POSTGRES_IMAGE=postgres:17-alpine
MINIO_IMAGE=minio/minio:latest
MINIO_CLIENT_IMAGE=minio/mc:latest
