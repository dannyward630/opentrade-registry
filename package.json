{
  "name": "opentrade-registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source framework for official contractor and skilled-trade license records.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "corepack pnpm -r build",
    "test": "vitest run",
    "typecheck": "corepack pnpm -r typecheck",
    "registry:validate": "vitest run tests/source-registry.test.ts",
    "cleanliness:scan": "node scripts/cleanliness-scan.mjs",
    "cli": "corepack pnpm --filter @opentrade/cli cli"
  },
  "devDependencies": {
    "@types/node": "^20.17.14",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
