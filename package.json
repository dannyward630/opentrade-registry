{
  "name": "opentrade-registry",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Local-first toolkit for working with official contractor and skilled-trade license records.",
  "license": "MIT",
  "homepage": "https://github.com/dannyward630/opentrade-registry",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dannyward630/opentrade-registry.git"
  },
  "bugs": {
    "url": "https://github.com/dannyward630/opentrade-registry/issues"
  },
  "keywords": [
    "contractor-licenses",
    "public-records",
    "license-verification",
    "typescript",
    "cli",
    "open-data",
    "florida-dbpr"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "verify": "corepack pnpm build && corepack pnpm typecheck && corepack pnpm api:typecheck && corepack pnpm test && corepack pnpm registry:validate && corepack pnpm db:seed:check && corepack pnpm cleanliness:scan && corepack pnpm files:check",
    "build": "corepack pnpm -r build",
    "test": "vitest run",
    "test:registry": "vitest run tests/source-registry.test.ts tests/source-quality-report.test.ts",
    "test:adapters": "vitest run tests/adapter-registry.test.ts tests/adapter-conformance.test.ts tests/adapter-level4.test.ts",
    "test:cli": "vitest run tests/cli-smoke.test.ts",
    "test:api": "vitest run tests/hosted-api.test.ts tests/network.test.ts",
    "typecheck": "corepack pnpm -r typecheck",
    "api:typecheck": "tsc -p tsconfig.api.json --noEmit",
    "registry:validate": "vitest run tests/source-registry.test.ts",
    "cleanliness:scan": "node scripts/cleanliness-scan.mjs",
    "files:check": "node scripts/files-check.mjs",
    "source:quality": "node scripts/source-quality-report.mjs",
    "db:seed:generate": "node scripts/generate-registry-source-seed.mjs",
    "db:seed:check": "node scripts/generate-registry-source-seed.mjs --check",
    "security:audit": "corepack pnpm audit --prod=false",
    "pack:check": "corepack pnpm build && node scripts/pack-check.mjs",
    "cli": "corepack pnpm --filter @opentrade/cli cli",
    "web:build": "corepack pnpm --filter @opentrade/web build",
    "web:dev": "corepack pnpm --filter @opentrade/web dev"
  },
  "devDependencies": {
    "@opentrade/adapter-fl-dbpr": "workspace:*",
    "@opentrade/adapter-or-ccb": "workspace:*",
    "@opentrade/adapter-tx-tdlr": "workspace:*",
    "@opentrade/adapter-wa-lni": "workspace:*",
    "@opentrade/core": "workspace:*",
    "@supabase/supabase-js": "^2.87.1",
    "@types/node": "^20.17.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
