{
  "name": "@opentrade/core",
  "version": "1.0.0",
  "type": "module",
  "description": "Shared schemas, adapter contracts, and normalization helpers for OpenTrade Registry.",
  "license": "MIT",
  "homepage": "https://github.com/dannyward630/opentrade-registry#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dannyward630/opentrade-registry.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/dannyward630/opentrade-registry/issues"
  },
  "keywords": [
    "opentrade",
    "contractor-licenses",
    "public-records",
    "license-verification",
    "zod",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "yauzl": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/yauzl": "^3.4.0"
  }
}
