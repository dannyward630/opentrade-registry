{
  "name": "@opentrade-registry/storage-sqlite",
  "version": "1.0.1",
  "type": "module",
  "description": "Driverless SQLite schema and row helpers for storing OpenTrade Registry canonical records.",
  "license": "MIT",
  "homepage": "https://github.com/dannyward630/opentrade-registry#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dannyward630/opentrade-registry.git",
    "directory": "packages/storage-sqlite"
  },
  "bugs": {
    "url": "https://github.com/dannyward630/opentrade-registry/issues"
  },
  "keywords": [
    "opentrade",
    "sqlite",
    "contractor-licenses",
    "public-records",
    "license-verification",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentrade-registry/core": "workspace:*",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.11"
  }
}
