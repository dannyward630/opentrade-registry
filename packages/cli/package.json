{
  "name": "@opentrade-registry/cli",
  "version": "1.0.1",
  "type": "module",
  "description": "Command-line interface for OpenTrade Registry.",
  "license": "MIT",
  "homepage": "https://github.com/dannyward630/opentrade-registry#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dannyward630/opentrade-registry.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/dannyward630/opentrade-registry/issues"
  },
  "keywords": [
    "opentrade",
    "cli",
    "contractor-licenses",
    "public-records",
    "license-verification",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "opentrade": "./dist/index.js"
  },
  "exports": {
    "./exit-codes": {
      "types": "./dist/exit-codes.d.ts",
      "import": "./dist/exit-codes.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/copy-cli-registry.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cli": "tsx src/index.ts"
  },
  "dependencies": {
    "@opentrade-registry/adapter-az-roc": "workspace:*",
    "@opentrade-registry/adapter-ca-cslb": "workspace:*",
    "@opentrade-registry/adapter-fl-dbpr": "workspace:*",
    "@opentrade-registry/adapter-mn-dli": "workspace:*",
    "@opentrade-registry/adapter-or-ccb": "workspace:*",
    "@opentrade-registry/adapter-tx-tdlr": "workspace:*",
    "@opentrade-registry/adapter-wa-lni": "workspace:*",
    "@opentrade-registry/core": "workspace:*",
    "@opentrade-registry/registry": "workspace:*",
    "@opentrade-registry/storage-sqlite": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
