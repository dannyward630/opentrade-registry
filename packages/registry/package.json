{
  "name": "@opentrade-registry/registry",
  "version": "1.0.0",
  "type": "module",
  "description": "Programmatic sync and verification orchestration for OpenTrade Registry.",
  "license": "MIT",
  "homepage": "https://github.com/dannyward630/opentrade-registry#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dannyward630/opentrade-registry.git",
    "directory": "packages/registry"
  },
  "bugs": { "url": "https://github.com/dannyward630/opentrade-registry/issues" },
  "keywords": ["opentrade", "contractor-licenses", "public-records", "license-verification", "typescript"],
